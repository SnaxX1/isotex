generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  username           String    @unique
  password           String
  full_name          String?
  role               String    @default("user")
  reset_token        String?
  reset_token_expiry DateTime?
  is_verified        Int       @default(1)
  verification_token String?
  orders             Order[]
}

model Product {
  id             Int     @id @default(autoincrement())
  title          String
  category       String
  price          String
  stock          Int
  status         String
  description    String?
  sustainability String?
  image          String?
}

model Project {
  id       Int     @id @default(autoincrement())
  title    String
  status   String
  location String?
  date     String?
  impact   String?
  type     String?
  progress Int?
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  joined_at DateTime @default(now())
}

model Order {
  id               Int      @id @default(autoincrement())
  user_id          Int
  user             User     @relation(fields: [user_id], references: [id])
  items            String
  total            Float
  payment_method   String
  status           String   @default("Pending")
  shipping_address String
  created_at       DateTime @default(now())
}

model Depo {
  id              Int      @id @default(autoincrement())
  full_name       String
  email           String
  phone           String?
  weight_kg       Float
  payout          Float
  delivery_method String
  status          String   @default("Pending")
  created_at      DateTime @default(now())
}
